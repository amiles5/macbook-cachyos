#!/bin/bash
# Toggle eDP-1 DPMS when lid closes/opens.
# Reads lid state from /proc/acpi and watches logind D-Bus for changes.

set -euo pipefail

dpms_edp1() {
    # Ensure hyprctl can find the running instance
    if [[ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
        local dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/hypr"
        [[ -d "$dir" ]] && HYPRLAND_INSTANCE_SIGNATURE=$(ls "$dir" | head -1)
        export HYPRLAND_INSTANCE_SIGNATURE
    fi
    hyprctl dispatch dpms "$1" eDP-1
}

apply_lid_state() {
    if grep -q "closed" /proc/acpi/button/lid/*/state 2>/dev/null; then
        dpms_edp1 off
    else
        dpms_edp1 on
    fi
}

# Apply current state immediately on start
apply_lid_state

# Watch logind for LidClosed property changes
gdbus monitor -y -d org.freedesktop.login1 -o /org/freedesktop/login1 \
    | grep --line-buffered "LidClosed" \
    | while read -r _; do
        apply_lid_state
    done
